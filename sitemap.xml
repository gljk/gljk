---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.sitemaps.org/schemas/sitemap/0.9 http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd"
        xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% for post in site.posts %}
    {% unless post.sitemap == false %}
  <url>
    <loc>{{ post.url | prepend: site.baseurl | prepend: site.url }}</loc>
    {% if post.last_modified_at or post.date %}
    <lastmod>{{ post.last_modified_at | default: post.date | date_to_xmlschema }}</lastmod>
    {% endif %}
  </url>
    {% endunless %}
  {% endfor %}

  {% for page in site.pages %}
    {% unless page.sitemap == false %}
  <url>
    <loc>{{ page.url | prepend: site.baseurl | prepend: site.url }}</loc>
    {% if page.last_modified_at or page.date %}
    <lastmod>{{ page.last_modified_at | default: page.date | date_to_xmlschema }}</lastmod>
    {% endif %}
  </url>
    {% endunless %}
  {% endfor %}

  {% for collection in site.collections %}
    {% unless collection.label == 'posts' %}
      {% for doc in collection.docs %}
        {% unless doc.sitemap == false %}
  <url>
    <loc>{{ doc.url | prepend: site.baseurl | prepend: site.url }}</loc>
    {% if doc.last_modified_at or doc.date %}
    <lastmod>{{ doc.last_modified_at | default: doc.date | date_to_xmlschema }}</lastmod>
    {% endif %}
  </url>
        {% endunless %}
      {% endfor %}
    {% endunless %}
  {% endfor %}

  {% for file in site.static_files %}
    {% if file.extname == '.pdf' and file.path contains 'assets/pdf' %}
  <url>
    <loc>{{ file.path | prepend: site.baseurl | prepend: site.url }}</loc>
  </url>
    {% endif %}
  {% endfor %}
</urlset>
